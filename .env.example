# ==========================================
# BUILDOGRAM PRODUCTION ENVIRONMENT CONFIG
# ==========================================

# ------------------------------------------
# 1. CORE APPLICATION (REQUIRED)
# ------------------------------------------
# The public URL of the website. Used for absolute URLs in SEO, sitemaps, and emails.
NEXT_PUBLIC_SITE_URL=https://www.buildogram.in

# Node environment. Should be "production" for real deployments.
NODE_ENV=production

# ------------------------------------------
# 2. DATABASE (REQUIRED FOR PROD)
# ------------------------------------------
# Neon PostgreSQL Connection String. If missing, the app falls back to localStorage/demo mode.
DATABASE_URL=postgres://user:password@ep-cold-shadow-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ------------------------------------------
# 3. AUTHENTICATION (REQUIRED FOR PROD)
# ------------------------------------------
# Secret key used for signing JWT tokens. Use a strong, random 64-character string.
# Example generator: `openssl rand -base64 32`
JWT_SECRET=super_secret_jwt_key_replace_me_in_production

# ------------------------------------------
# 4. OPS ADMIN (REQUIRED)
# ------------------------------------------
# These credentials will be the primary super admin for the Ops Dashboard.
# Only the email is strictly necessary for notifications, but phone is good for WhatsApp.
OPS_ADMIN_EMAIL=ops@buildogram.in
OPS_ADMIN_PHONE=+919876543210

# ------------------------------------------
# 5. NOTIFICATIONS - EMAIL (OPTIONAL)
# ------------------------------------------
# Missing these will not crash the app, but email notifications will be skipped.
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=SG.your_api_key_here
EMAIL_FROM=noreply@buildogram.in

# ------------------------------------------
# 6. NOTIFICATIONS - WHATSAPP (OPTIONAL)
# ------------------------------------------
# Missing these will not crash the app, but WhatsApp notifications will be skipped.
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_KEY=your_twilio_auth_token
WHATSAPP_SENDER_ID=+1234567890
